    def get_gtk_color(self):
    
        try:
    
            # --------------------------
            # DARK / LIGHT MODE
            # --------------------------
    
            out = subprocess.check_output([
                "gsettings",
                "get",
                "org.gnome.desktop.interface",
                "color-scheme"
            ]).decode()
    
            mode = "-dark" if "prefer-dark" in out else ""
    
            # --------------------------
            # WALLPAPER URI
            # --------------------------
    
            uri = subprocess.check_output([
                "gsettings",
                "get",
                "org.gnome.desktop.background",
                f"picture-uri{mode}"
            ]).decode().strip()
    
            uri = uri.strip("'")
    
            if uri.startswith("file://"):
                wallpaper = uri[7:]
            else:
                wallpaper = uri
    
            # --------------------------
            # DOMINANT COLOR REAL
            # --------------------------
    
            cmd = f"""
    convert "{wallpaper}" -resize 100x100 -colors 16 -depth 8 \
    -format %c histogram:info:- | \
    awk -F'[(), ]+' '
    function rgb_to_hue(r,g,b){{
        r/=255; g/=255; b/=255;
    
        max=(r>g?r:g);
        max=(max>b?max:b);
    
        min=(r<g?r:g);
        min=(min<b?min:b);
    
        d=max-min;
    
        if(d==0) return -1;
    
        if(max==r) h=(g-b)/d;
        else if(max==g) h=2+(b-r)/d;
        else h=4+(r-g)/d;
    
        h*=60;
    
        if(h<0) h+=360;
    
        return h;
    }}
    
    {{
        count=$1;
        r=$3;
        g=$4;
        b=$5;
    
        max=(r>g?r:g);
        max=(max>b?max:b);
    
        min=(r<g?r:g);
        min=(min<b?min:b);
    
        sat=max-min;
    
        if(sat < 25) next;
    
        score = count * (sat + 10);
    
        printf("%f %d %d %d\\n", score, r, g, b);
    }}
    ' | sort -nr | head -n1
    """
    
            out = subprocess.check_output(
                cmd,
                shell=True
            ).decode().strip()
    
            parts = out.split()
    
            r = int(parts[1]) / 255
            g = int(parts[2]) / 255
            b = int(parts[3]) / 255
    
            return (
                round(r, 3),
                round(g, 3),
                round(b, 3)
            )
    
        except Exception as e:
    
            print("Wallpaper color error:", e)
    
            return (0.12, 0.12, 0.12)
