        title = get_metadata("title")

        song = f"{artist} - {title}"

        if song != current_song[0]:
            current_song[0] = song

            # limpiar inmediatamente
            global lyrics
            lyrics = []

            win.set_lines("", f"{artist} - {title}", "")

            load_lrc()

        return True
    
    def update():
    
        # 🔥 SI NO HAY LETRAS, SOLO MOSTRAR TÍTULO FIJO
        if not lyrics:
            artist = get_metadata("artist")
            title = get_metadata("title")
            
            if not artist and not title:
                win.set_lines("", "-", "")
                return True
            
            if not lyrics:
                win.set_lines("", f"{artist} - {title}", "")
                return True
    
        # reloj
        if win.show_clock:
            win.queue_draw()
    
        # lyrics sync
    
        t = globals()["get_position"]()
    
        first_time = lyrics[0][0] if lyrics else 0
        
        if t < first_time:
            artist = get_metadata("artist")
            title = get_metadata("title")
        
            win.set_lines(
                "",
                f"{artist} — {title}",
                ""
            )
    
            return True
        
        idx = 0
        for i in range(len(lyrics)):
            if lyrics[i][0] <= t:
                idx = i
            else:
                break
    
        prev = lyrics[idx - 1][1] if idx > 0 else ""
        curr = lyrics[idx][1]
        next_ = lyrics[idx + 1][1] if idx + 1 < len(lyrics) else ""
    
        win.set_lines(prev, curr, next_)
    
        return True
        
    win = LyricsWidget(load_lrc)

    GLib.timeout_add(1000, check_song_change)
    GLib.timeout_add(2000, update)

    Gtk.main()


if __name__ == "__main__":
    lyrics = []
    print("Lyrics Widget")
    main()
