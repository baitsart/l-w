# ---------------- NORMALIZE ----------------

def normalize(text):
    text = text.lower()

    # basura común
    text = re.sub(r"\b(song|album|official|video|lyrics)\b", "", text)

    # conservar mixes/versiones
    # text = re.sub(r"\(.*?\)", "", text)
    text = re.sub(r"\[.*?\]", "", text)
    text = re.sub(r"feat\.?.*", "", text)
    text = re.sub(r"\bft\.?.*", "", text)

    text = re.sub(r"\d+", "", text)
    text = re.sub(r"[^\w\s]", " ", text)
    text = re.sub(r"\s+", " ", text)

    return text.strip()


def similarity(a, b):
    return SequenceMatcher(None, a, b).ratio()

def get_final_names(artist, title):
    if search_override:
        txt = normalize(search_override)

        # 🔥 intentamos detectar artista real desde metadata si existe
        meta_artist = normalize(get_metadata("artist"))
        meta_title = normalize(get_metadata("title"))

        txt_words = txt.split()
        meta_words = meta_artist.split()

        # 🔥 si coincide parcialmente con artista real → lo respetamos
        if meta_words and len(set(meta_words) & set(txt_words)) >= 1:
            artist = meta_artist
            title = " ".join([w for w in txt_words if w not in meta_words])
        else:
            # fallback: todo es título
            title = txt

    return artist.strip(), title.strip()
    
def get_contrast_color(r, g, b):
    luminance = 0.299 * r + 0.587 * g + 0.114 * b

    if luminance > 0.65:
        return "black"
    else:
        return "white"

# ---------------- INDEX ----------------

def build_index():
    base = LYRICS_DIR
    index = []

    for root, dirs, files in os.walk(base):

        for f in files:

            if not f.endswith(".lrc"):
                continue

            full_path = os.path.join(root, f)

            rel = os.path.relpath(full_path, base)

            parts = rel.split(os.sep)

            artist = ""
            album = ""
            title = f.replace(".lrc", "")

            if len(parts) >= 3:
                artist = parts[0]
                album = parts[1]
                title = os.path.splitext(parts[2])[0]
                
                # 🔥 quitar artista duplicado del filename
                if artist:
                
                    norm_artist = normalize(artist)
                    norm_title = normalize(title)
                
                    if norm_title.startswith(norm_artist):
                
                        title = re.sub(
                            rf"^{re.escape(artist)}\s*-\s*",
                            "",
                            title,
                            flags=re.I
                        )

            elif len(parts) == 2:
                artist = parts[0]
                title = os.path.splitext(parts[1])[0]

            index.append({
                "artist": normalize(artist),
                "album": normalize(album),
                "title": normalize(title),
                "path": full_path
            })

    return index


# ---------------- LRC ----------------

def parse_lrc(file):
    pattern = re.compile(r"\[(\d+):([\d.]+)\](.*)")
    data = []

    with open(file) as f:
        for line in f:
            m = pattern.match(line)
            if m:
                mnt = int(m.group(1))
                sec = float(m.group(2))
                txt = m.group(3).strip()
                data.append((mnt * 60 + sec, txt))

    return data

def fetch_lrc_online(artist, title):
    try:
        url = "https://lrclib.net/api/get"

        params = {
            "artist_name": artist,
            "track_name": title
        }

        r = requests.get(url, params=params, timeout=12)

        if r.status_code == 200:
            data = r.json()

            if "syncedLyrics" in data and data["syncedLyrics"]:
                return data["syncedLyrics"]

    except Exception as e:
        print("Error online:", e)

    return None

def fetch_lrc_youtube(artist, title):
    import threading

    key = f"{artist} - {title}"

    # 🔥 evitar repetir
    if key in YT_CACHE or key in YT_FAILED:
        return None

    # 🔥 evitar múltiples ejecuciones simultáneas
    if hasattr(fetch_lrc_youtube, "running") and fetch_lrc_youtube.running:
        return None

    fetch_lrc_youtube.running = True

    def worker():
        try:
            subprocess.run(
                ["yt-lyrics", artist, title],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            )

            base = LYRICS_DIR

            safe_artist = re.sub(r'[\\/:"*?<>|]+', "", artist)
            safe_title = re.sub(r'[\\/:"*?<>|]+', "", title)

            path = os.path.join(base, safe_artist, f"{safe_title}.lrc")

            global lyrics, lyrics_source

            if os.path.exists(path):
                lyrics = parse_lrc(path)
                lyrics_source = "YOUTUBE"

                YT_CACHE.add(key)
                print("🎧 YouTube OK (cached)")
            else:
                YT_FAILED.add(key)
                print("❌ YouTube sin resultado (cached)")

        except Exception as e:
            YT_FAILED.add(key)
            print("Error YouTube:", e)

        finally:
            fetch_lrc_youtube.running = False

    threading.Thread(target=worker, daemon=True).start()

    return None

def make_lrc_path(artist, title, album="Unknown Album"):
    artist, title = get_final_names(artist, title)

    safe_artist = re.sub(r'[\\/:"*?<>|]+', "", artist).title()
    safe_title = re.sub(r'[\\/:"*?<>|]+', "", title).title()
    safe_album = re.sub(r'[\\/:"*?<>|]+', "", album).title()

    album_dir = os.path.join(LYRICS_DIR, safe_artist, safe_album)
    os.makedirs(album_dir, exist_ok=True)

    return os.path.join(album_dir, f"{safe_title}.lrc")
    
   
def format_time(sec):
    m = int(sec // 60)
    s = int(sec % 60)
    return f"{m:02}:{s:02}"

def safe_markup(text):

    # permitir solo <i>
    text = text.replace("&", "&amp;")
    text = text.replace("<i>", "__ITALIC_OPEN__")
    text = text.replace("</i>", "__ITALIC_CLOSE__")
    text = text.replace("<", "&lt;")
    text = text.replace(">", "&gt;")
    text = text.replace("__ITALIC_OPEN__", "<i>")
    text = text.replace("__ITALIC_CLOSE__", "</i>")

    return text

