    def get_scaled_skin_size(self):
    
        if not self.skin:
            return (740, 250)
    
        sw = self.skin.get_width()
        sh = self.skin.get_height()
    
        scale = DEFAULT_SCALE
    
        w = int(sw * scale)
        h = int(sh * scale)
    
        # límites razonables
        w = min(w, 1200)
        h = min(h, 700)
    
        return (w, h)

    def set_clickable(self):
    
        window = self.get_window()
    
        if not window:
            return False
    
        alloc = self.get_allocation()
    
        if self.clickable:
    
            # toda la ventana clickeable
            region = cairo.Region(
                cairo.RectangleInt(
                    0,
                    0,
                    alloc.width,
                    alloc.height
                )
            )
    
        else:
    
            # todo transparente EXCEPTO esquina resize
            region = cairo.Region()
    
            resize_corner = cairo.RectangleInt(
                alloc.width - 28,
                alloc.height - 28,
                28,
                28
            )
    
            region.union(resize_corner)
    
        window.input_shape_combine_region(region, 0, 0)
    
        return False
        
    def on_configure(self, widget, event):
    
        # ignorar configure si no estamos en resize real
        if not self.resizable_mode:
            return False

        if self.ignore_configure:
            return False
    
        # cancelar timer anterior
        if self.resize_timer:
            GLib.source_remove(self.resize_timer)
    
        # guardar SOLO cuando termina resize
        self.resize_timer = GLib.timeout_add(
            1200,
            self.delayed_save
        )
    
        return False

    def delayed_save(self):
    
        self.resize_timer = None
    
        current_w, current_h = self.get_size()
    
        # evitar tamaños basura
        if current_w < 250 or current_h < 120:
            print(f"⚠️ Ignorado tamaño basura: {current_w}x{current_h}")
            return False
    
        self.save_window_state()
    
        return False

    def finish_theme_resize(self):
    
        self.ignore_configure = False
    
        w, h = self.get_size()
    
        if w >= 250 and h >= 120:
            self.save_window_state()
    
        return False

    def toggle_resize(self, widget):
    
        self.resizable_mode = widget.get_active()
    
        # 🔥 guardar tamaño REAL ACTUAL antes de tocar decoraciones
        alloc = self.get_allocation()
    
        current_w = alloc.width
        current_h = alloc.height
    
        if self.resizable_mode:
    
            self.clickable = True
            self.set_clickable()
    
            self.set_decorated(True)
            self.set_resizable(True)
    
            # 🔥 restaurar tamaño exacto
            GLib.idle_add(
                lambda: self.resize(current_w, current_h)
            )
    
            print("📐 Resize ON")
    
        else:
    
            if self.resize_timer:
                GLib.source_remove(self.resize_timer)
                self.resize_timer = None
    
            # 🔥 guardar tamaño ANTES de sacar bordes
            self.save_window_state()
    
            self.set_decorated(False)
    
            # 🔥 volver a forzar tamaño exacto
            GLib.idle_add(
                lambda: self.resize(current_w, current_h)
            )
    
            GLib.timeout_add(
                300,
                self.set_clickable
            )
    
            print("📐 Resize OFF")
    
        self.queue_draw()
        
    def on_click(self, widget, event):
    
        # 🔥 resize manual esquina inferior derecha
        if (
            not self.clickable
            and event.button == 1
        ):
    
            alloc = self.get_allocation()
    
            corner_size = 28
    
            if (
                event.x >= alloc.width - corner_size
                and event.y >= alloc.height - corner_size
            ):
    
                self.begin_resize_drag(
                    Gdk.WindowEdge.SOUTH_EAST,
                    event.button,
                    int(event.x_root),
                    int(event.y_root),
                    event.time
                )
    
                return True
    
        # 🔥 DOBLE CLICK IZQUIERDO → mover
        if (
            event.type == Gdk.EventType._2BUTTON_PRESS
            and event.button == 1
        ):
    
            self.begin_move_drag(
                event.button,
                int(event.x_root),
                int(event.y_root),
                event.time
            )
    
            return True
    
        # 🔥 CLICK DERECHO → menú
        if event.button == 3:
    
            menu = Gtk.Menu()
    
            def add_item(label, callback):
                item = Gtk.MenuItem(label=label)
                item.connect("activate", callback)
                menu.append(item)
    
            def toggle_item(label, attr):
                item = Gtk.CheckMenuItem(label=label)
                item.set_active(getattr(self, attr, False))
                item.connect(
                    "toggled",
                    lambda w: setattr(self, attr, w.get_active())
                )
                menu.append(item)
    
            add_item("Editar búsqueda", self.edit_name)
            add_item("Sincronizar (min:seg)", self.sync_time)
    
            add_item("📝 Texto a Lyrics", self.text_to_lyrics)
            add_item("🎨 Seleccionar tema", self.select_theme)
            add_item("🌫️ Opacidad", self.change_opacity)
    
            menu.append(Gtk.SeparatorMenuItem())
    
            toggle_item("Mostrar reloj", "show_clock")
    
            resize_item = Gtk.CheckMenuItem(label="Redimensionar")
            resize_item.set_active(self.resizable_mode)
            resize_item.connect("toggled", self.toggle_resize)
            menu.append(resize_item)
    
            menu.append(Gtk.SeparatorMenuItem())
    
            skin_toggle = Gtk.CheckMenuItem(label="Skins activados")
            skin_toggle.set_active(self.use_skin)
            skin_toggle.connect("toggled", self.toggle_skin)
            menu.append(skin_toggle)
    
            click_toggle = Gtk.CheckMenuItem(label="Clickable")
            click_toggle.set_active(self.clickable)
            click_toggle.connect(
                "toggled",
                self.toggle_clickable
            )
            menu.append(click_toggle)
    
            top_toggle = Gtk.CheckMenuItem(
                label="Mostrar siempre encima"
            )
            top_toggle.set_active(self.always_on_top)
            top_toggle.connect(
                "toggled",
                self.toggle_always_on_top
            )
            menu.append(top_toggle)
            
            translate_toggle = Gtk.CheckMenuItem(
                label="Mostrar traducción"
            )
            
            translate_toggle.set_active(show_translation)
            
            translate_toggle.connect(
                "toggled",
                self.toggle_translation
            )
            
            menu.append(translate_toggle)            
    
            add_item("Salir", Gtk.main_quit)
    
            menu.show_all()
            menu.popup_at_pointer(event)
    
            return True
    
        return False            

    def toggle_skin(self, widget):
    
        self.use_skin = widget.get_active()
    
        self.save_ui_state()
    
        self.queue_draw()
        
    def toggle_clickable(self, widget):
        self.clickable = widget.get_active()
    
        self.set_clickable()
    
        print(
            "🖱️ Clickable:",
            "ON" if self.clickable else "CLICK-THROUGH"
        )
    
    def toggle_always_on_top(self, widget):
        self.always_on_top = widget.get_active()
    
        self.set_keep_above(self.always_on_top)
    
        print(
            "📌 Siempre encima:",
            "ON" if self.always_on_top else "OFF"
        )

    def toggle_translation(self, widget):
    
        global show_translation
    
        show_translation = widget.get_active()
    
        print(
            "🌎 Traducción:",
            "ON" if show_translation else "OFF"
        )
    
        # persistencia
        if show_translation:
            open(TRANSLATION_FLAG, "w").close()
        else:
            try:
                os.remove(TRANSLATION_FLAG)
            except:
                pass
    
        # recargar letras
        global lyrics
        lyrics = []
    
        if self.load_lrc_func:
            self.load_lrc_func()
    
        self.queue_draw()
    
        GLib.timeout_add(
            100,
            self.set_clickable
        )

