PLAYER = None

def get_player():
    global PLAYER

    try:
        out = subprocess.check_output(
            ["playerctl", "-l"],
            stderr=subprocess.DEVNULL
        ).decode().splitlines()

        preferred = [
            "rhythmbox",
            "clementine",
            "vlc",
            "mpv"
        ]

        for p in preferred:
            for found in out:
                if found.startswith(p):
                    PLAYER = found
                    return PLAYER

        if out:
            PLAYER = out[0]
            return PLAYER

    except:
        pass

    return None

