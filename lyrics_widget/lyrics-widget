    def get_skin_average_color(self, surface):
    
        try:
            data = surface.get_data()
            w = surface.get_width()
            h = surface.get_height()
            stride = surface.get_stride()
    
            r_total = 0
            g_total = 0
            b_total = 0
            count = 0
    
            for y in range(0, h, 4):
                for x in range(0, w, 4):
    
                    i = y * stride + x * 4
    
                    b = data[i]
                    g = data[i + 1]
                    r = data[i + 2]
    
                    r_total += r
                    g_total += g
                    b_total += b
    
                    count += 1
    
            return (
                (r_total / count) / 255,
                (g_total / count) / 255,
                (b_total / count) / 255
            )
    
        except Exception as e:
    
            print("Skin color error:", e)
    
            return self.bg_color

