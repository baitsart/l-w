    def draw_rounded_rect(self, cr, x, y, w, h, r):
        cr.new_sub_path()
        cr.arc(x + w - r, y + r, r, -1.57, 0)
        cr.arc(x + w - r, y + h - r, r, 0, 1.57)
        cr.arc(x + r, y + h - r, r, 1.57, 3.14)
        cr.arc(x + r, y + r, r, 3.14, 4.71)
        cr.close_path()

    def on_draw(self, widget, cr):
        
        w, h = self.get_allocation().width, self.get_allocation().height
        
        # solo limpiar con fondo transparente implícito
        cr.set_operator(cairo.OPERATOR_SOURCE)
        cr.set_source_rgba(0, 0, 0, 0)
        cr.paint()
        cr.set_operator(cairo.OPERATOR_OVER)
    
        if self.skin and self.use_skin:
            r, g, b = self.skin_color
        else:
            r, g, b = self.bg_color
        
        contrast = get_contrast_color(r, g, b)
        
        if contrast == "black":
        
            main_color = (0, 0, 0, 1)
            secondary_color = (0.15, 0.15, 0.15, 0.85)
        
        else:
        
            main_color = (1, 1, 1, 1)
            secondary_color = (0.8, 0.8, 0.8, 0.85)        
    
        # -------------------------
        # LIMPIEZA REAL DEL CANVAS
        # -------------------------
        cr.set_operator(cairo.OPERATOR_CLEAR)
        cr.paint()
        cr.set_operator(cairo.OPERATOR_OVER)
    
        # -------------------------
        # CLIP (bordes redondeados)
        # -------------------------
        self.draw_rounded_rect(cr, 0, 0, w, h, self.radius)
        cr.clip()
        
        # -------------------------
        # FONDO BASE: SKIN (PURA IMAGEN)
        # -------------------------
        if self.skin and self.use_skin:
        
            sw = self.skin.get_width()
            sh = self.skin.get_height()
        
            cr.save()
        
            # usar la imagen directamente SIN pattern raro
            scale_x = w / sw
            scale_y = h / sh
            
            cr.scale(scale_x, scale_y)
            cr.set_source_surface(self.skin, 0, 0)
            cr.paint()
        
            cr.restore()
        
        # -------------------------
        # -------------------------
        # BACKGROUND DECISION CLARA (sin mezcla)
        # -------------------------
        
        if self.skin and self.use_skin:
            # 🔥 skin puro total
            pass
        else:
            r, g, b = self.bg_color
        
            # usar opacidad configurable
            cr.set_source_rgba(
                r,
                g,
                b,
                self.opacity
            )
        
            cr.paint()
    
        # -------------------------
        # BLUR SIMULADO (solo sin skin)
        # -------------------------
        if not (self.skin and self.use_skin):
        
            r, g, b = self.bg_color
        
            for i in range(4):
                alpha = 0.02
                offset = i * 2
        
                self.draw_rounded_rect(
                    cr,
                    offset,
                    offset,
                    w - offset * 2,
                    h - offset * 2,
                    self.radius
                )
        
                cr.set_source_rgba(r, g, b, alpha)
                cr.fill()
    
        # -------------------------
        # BRILLO SUPERIOR
        # -------------------------
        if not (self.skin and self.use_skin):
            gradient = cairo.LinearGradient(0, 0, 0, h)
            gradient.add_color_stop_rgba(0, 1, 1, 1, 0.18)
            gradient.add_color_stop_rgba(1, 1, 1, 1, 0.0)
        
            cr.set_source(gradient)
            cr.paint()
            
        # -------------------------
        # TEXTO (Pango)
        # -------------------------
        layout = PangoCairo.create_layout(cr)
    
        main_size = max(12, int(self.font_main * (h / 220)))
        sec_size = max(10, int(self.font_secondary * (h / 220)))
    
        # prev
        layout.set_markup(safe_markup(self.prev_text))
        layout.set_font_description(Pango.FontDescription(f"Sans {sec_size}"))
        layout.set_width((w - 40) * Pango.SCALE)
        layout.set_alignment(Pango.Alignment.CENTER)
        layout.set_wrap(Pango.WrapMode.WORD_CHAR)
    
        cr.set_source_rgba(*secondary_color)
        cr.move_to(20, h * 0.22)
        PangoCairo.show_layout(cr, layout)
    
        # current
        layout.set_markup(safe_markup(self.curr_text))
        layout.set_font_description(Pango.FontDescription(f"Sans Bold {main_size}"))
    
        cr.set_source_rgba(*main_color)
        cr.move_to(20, h * 0.42)
        PangoCairo.show_layout(cr, layout)
    
        # next
        layout.set_markup(safe_markup(self.next_text))
        layout.set_font_description(Pango.FontDescription(f"Sans {sec_size}"))
    
        cr.set_source_rgba(*secondary_color)
        cr.move_to(20, h * 0.72)
        PangoCairo.show_layout(cr, layout)

        # ---------------- CLOCK ----------------
        if self.show_clock:
        
            pos = get_position()
            length = get_length()
        
            if length > 0:
                txt = f"{format_time(pos)} / {format_time(length)}"
            else:
                txt = format_time(pos)
        
            clock_layout = PangoCairo.create_layout(cr)
            clock_layout.set_text(txt, -1)
            clock_layout.set_font_description(Pango.FontDescription("Sans 11"))
        
            margin = int(h * 0.08)
        
            text_w, text_h = clock_layout.get_size()
            text_w = text_w / Pango.SCALE
            text_h = text_h / Pango.SCALE
        
            cr.set_source_rgba(1, 1, 1, 0.85)
        
            cr.move_to(
                (w - text_w) / 2,
                h - margin - text_h
            )
        
            PangoCairo.show_layout(cr, clock_layout)

