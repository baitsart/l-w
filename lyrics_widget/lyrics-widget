                        for t, txt in yt_lrc:
                            m = int(t // 60)
                            s = t % 60
                            f.write(f"[{m:02}:{s:05.2f}]{txt}\n")

                lyrics = yt_lrc
                lyrics_source = "YOUTUBE"

                # 🔥 reset automático
