    def finish_sync_mode(self):
        global sync_mode, sync_output_path

        sync_mode = False

        if not hasattr(self, "sync_result"):
            print("Nada sincronizado")
            return

        os.makedirs(os.path.dirname(sync_output_path), exist_ok=True)

        with open(sync_output_path, "w") as f:
            for t, line in self.sync_result:
                m = int(t // 60)
                s = t % 60
                f.write(f"[{m:02}:{s:05.2f}]{line}\n")

        print("💾 LRC guardado:", sync_output_path)

        self.sync_result = []

