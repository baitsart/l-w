    def load_lrc():
        nonlocal current_song
        global lyrics, lyrics_source
    
        artist = get_metadata("artist")
        title = get_metadata("title")
    
        if not artist and not title:
            win.set_lines("", "-", "")
            return
    
        # ---------------------------
        # TARGET REAL (override o canción actual)
        # ---------------------------
        if search_override:
            target = normalize(search_override)
        else:
            target = normalize(f"{artist} {title}")
    
        print("TARGET:", target)
    
        # ---------------------------
        # MATCH LOCAL INDEX
        # ---------------------------
        
        best_score = 0
        best_match = None
        
        norm_title = normalize(title)
        norm_artist = normalize(artist)
        
        # ---------------------------------
        # 1. MATCH EXACTO PRIMERO
        # ---------------------------------
        
        for item in lyrics_index:
        
            item_title = normalize(item["title"])
            item_artist = normalize(item["artist"])
        
            if (
                item_title == norm_title
                and item_artist == norm_artist
            ):
                best_match = item["path"]
                best_score = 1.0
        
                print("✅ MATCH EXACTO")
        
                break
        
        # ---------------------------------
        # 2. FALLBACK DIFUSO
        # ---------------------------------
        
        if not best_match:
        
            for item in lyrics_index:
        
                item_title = normalize(item["title"])
                item_artist = normalize(item["artist"])
        
                title_score = similarity(item_title, norm_title)
                artist_score = similarity(item_artist, norm_artist)
        
                # más estricto
                if title_score < 0.75:
                    continue
        
                score = (
                    title_score * 0.8
                    + artist_score * 0.2
                )
        
                if score > best_score:
                    best_score = score
                    best_match = item["path"]
        
        print("BEST SCORE:", best_score)
    
        # ---------------------------
        # SI ES BUEN MATCH LOCAL
        # ---------------------------
        
        # umbral más estricto
        if best_score > 0.75 and best_match:
    
            print("Lyrics encontrados:", best_match)
    
            load_path = best_match
            
            if show_translation:
            
                translated = best_match + ".translates"
            
                if os.path.exists(translated):
                    load_path = translated
            
            lyrics = parse_lrc(load_path)
            lyrics_source = f"LOCAL: {os.path.basename(best_match)}"

            # 🔥 reset automático
            if search_override:
                globals()["search_override"] = None
                print("🔄 Override auto-reset")

            print("📁 Archivo local:", best_match)
    
            if lyrics:
                GLib.idle_add(
                    win.set_lines,
                    "",
                    lyrics[0][1],
                    lyrics[1][1] if len(lyrics) > 1 else ""
                )
    
            return
    
        # ---------------------------
        # LRCLIB ONLINE
        # ---------------------------
        print("Buscando en LRCLIB...")
    
        lrc_text = fetch_lrc_online(artist, title)
    
        if lrc_text:

            album = get_album()

            path = make_lrc_path(
                artist,
                title,
                album
            )

            if os.path.exists(path) and not search_override:
                print("♻️ Ya existe:", path)
            else:
                with open(path, "w") as f:
                    f.write(lrc_text)

            lyrics = []

            for line in lrc_text.split("\n"):
                m = re.match(r"\[(\d+):([\d.]+)\](.*)", line)

                if m:
                    mnt = int(m.group(1))
                    sec = float(m.group(2))
                    txt = m.group(3).strip()

